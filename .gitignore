# OS / editor junk
Thumbs.db
Desktop.ini
.DS_Store
*.swp

# sync lock (created by bin/sync-push.sh)
.sync.lock

# per-file narrative append lock (created by bin/claude-worklog-hook.sh SessionEnd backstop)
narrative/*.lock

# obligation-ledger append lock (created by bin/session-obligations.sh). The .ndjson ledger
# itself IS tracked + pushed (sync-push.sh stages obligations/); only the lock is ignored.
obligations/*.lock
